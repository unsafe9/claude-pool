{
  "description": "claude-pool: automatic Claude Code credential swapping across pooled subscription accounts (API keys as fallback)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": ["-c", "[ -f \"${CLAUDE_PLUGIN_ROOT:-}/hooks/scripts/bootstrap.sh\" ] && exec sh \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/bootstrap.sh\"; exit 0"],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell.exe",
            "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", "if (Test-Path \"${env:CLAUDE_PLUGIN_ROOT}\\hooks\\scripts\\bootstrap.ps1\") { & \"${env:CLAUDE_PLUGIN_ROOT}\\hooks\\scripts\\bootstrap.ps1\" }"],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "claude-pool",
            "args": ["hook", "session-start"],
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-pool",
            "args": ["hook", "background"],
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-pool",
            "args": ["hook", "stop-failure"],
            "timeout": 20
          }
        ]
      }
    ]
  }
}
