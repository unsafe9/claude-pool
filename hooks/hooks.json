{
  "description": "claude-pool: automatic Claude Code credential swapping across pooled subscription accounts (API keys as fallback)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-pool",
            "args": ["hook", "session-start"],
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-pool",
            "args": ["hook", "background"],
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-pool",
            "args": ["hook", "stop-failure"],
            "timeout": 20
          }
        ]
      }
    ]
  }
}
